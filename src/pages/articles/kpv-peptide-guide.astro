const rawHTML = `
<div class="c">

<!-- Hero -->
<div class="hero">
  <div class="hero-k">Peptide Guide &middot; Anti-Inflammatory &middot; Gut Health</div>
  <h1>KPV Peptide: The Anti-Inflammatory Tripeptide for Gut Health</h1>
  <p class="sub">A tiny three-amino-acid fragment of alpha-MSH with potent anti-inflammatory effects, oral bioavailability, and strong preclinical data for IBD and colitis. What the research actually shows and what remains unknown.</p>
