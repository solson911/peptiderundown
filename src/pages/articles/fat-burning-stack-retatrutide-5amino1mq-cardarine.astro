  </div>
</div>

<!-- Stats -->
<div class="sr">
  <div class="sb"><div class="v c1">3</div><div class="l">Distinct Metabolic<br>Pathways Targeted</div></div>
  <div class="sb"><div class="v c2">15%</div><div class="l">Avg Weight Loss<br>Retatrutide (24 wk)</div></div>
  <div class="sb"><div class="v c3">NNMT</div><div class="l">Enzyme Target<br>of 5-Amino-1MQ</div></div>
