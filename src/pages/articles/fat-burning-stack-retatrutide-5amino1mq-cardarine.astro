const rawHTML = `
<div class="c">

<!-- Hero -->
<div class="hero">
  <div class="hero-k">Peptide Stack &middot; Fat Loss &middot; Metabolic Research</div>
  <h1>Advanced Fat Burning Stack: Retatrutide + 5-Amino-1MQ + Cardarine</h1>
  <p class="sub">Three compounds targeting three distinct metabolic pathways: appetite regulation, fat cell reprogramming, and fatty acid oxidation. A research stack designed for multi-angle fat loss investigation.</p>
  <div class="pills">
    <span class="pill">Triple GIP/GLP-1/Glucagon Agonist</span>
    <span class="pill">NNMT Inhibitor</span>
