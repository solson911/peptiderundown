---
import Base from '../../layouts/Base.astro';

export const frontmatter = {
  title: "Peptide Dosing Calculator: Reconstitution Math Made Simple",
  description: "Learn how to calculate peptide doses, reconstitution volumes, and read insulin syringes. Step-by-step math with worked examples for BPC-157, semaglutide, ipamorelin, and more.",
  image: "/images/articles/peptide-dosing-calculator.webp",
  date: "2026-01-07",
  category: "How-To",
  author: "PeptideRundown Team"
};
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const rawCSS = `
