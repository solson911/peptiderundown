const rawHTML = `
<div class="c">

<!-- Hero -->
<div class="hero">
  <div class="hero-k">How-To &middot; Delivery &middot; Practical Guide</div>
  <h1>Peptide Delivery Forms: Injectable vs Nasal vs Oral vs Topical</h1>
  <p class="sub">The delivery route can matter as much as the compound itself. A practical breakdown of how each form works, what gets absorbed, and the tradeoffs that actually matter for safety and outcomes.</p>
  <div class="pills">
    <span class="pill">Injectable &middot; Subcutaneous</span>
    <span class="pill">Intranasal &middot; Sublingual</span>
    <span class="pill">Oral &middot; Topical</span>
  </div>
</div>

<!-- Stats -->
<div class="sr">
  <div class="sb"><div class="v c1">5</div><div class="l">Major Delivery<br>Routes</div></div>
  <div class="sb"><div class="v c2">90%+</div><div class="l">Injectable<br>Bioavailability</div></div>
  <div class="sb"><div class="v c3">&lt;10%</div><div class="l">Typical Oral<br>Bioavailability</div></div>
