<!-- Stats -->
<div class="sr">
  <div class="sb"><div class="v c1">40%</div><div class="l">Female Share of<br>Peptide Prescriptions</div></div>
  <div class="sb"><div class="v c2">10+</div><div class="l">Peptides Covered<br>With Female Dosing</div></div>
