const rawHTML = `
<div class="c">

<!-- Hero -->
<div class="hero">
  <div class="hero-k">Peptide Guide &middot; Women's Health &middot; Protocols</div>
  <h1>Peptides for Women: Complete Guide to Female-Specific Protocols</h1>
  <p class="sub">Women's bodies respond differently to peptides than men's. This guide covers the science, the specific compounds, and the cycle-aware protocols that actually work for female physiology.</p>
  <div class="pills">
    <span class="pill">Hormones &middot; Cycle Timing</span>
