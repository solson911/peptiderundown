    <text x="520" y="72" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="9" fill="#B48118" letter-spacing="1" font-weight="600">PRODUCTION</text>
    <line x1="475" y1="80" x2="565" y2="80" stroke="#B48118" stroke-opacity=".2"/>
    <text x="520" y="100" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="10" fill="#5A4010">Dark melanin made</text>
    <text x="520" y="115" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="10" fill="#5A4010">and distributed</text>
    <text x="520" y="145" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="9" fill="#B48118" font-weight="600">STEP 4</text>

