    <!-- Arrow 4 -->
    <line x1="585" y1="100" x2="605" y2="100" stroke="#86869A" stroke-width="1.5" marker-end="url(#arrow)"/>

    <rect x="610" y="45" width="80" height="110" rx="10" fill="#FDEEEC" stroke="#B53A3A" stroke-width="1.5"/>
