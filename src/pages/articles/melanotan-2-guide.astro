    <!-- Arrow 3 -->
    <line x1="435" y1="100" x2="455" y2="100" stroke="#86869A" stroke-width="1.5" marker-end="url(#arrow)"/>

    <!-- Step 4: Eumelanin -->
    <rect x="460" y="30" width="120" height="140" rx="10" fill="#FFF7E5" stroke="#B48118" stroke-width="1.5"/>
