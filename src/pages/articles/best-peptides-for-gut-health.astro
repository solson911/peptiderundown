<tbody>
<tr><td><strong>Primary action</strong></td><td class="g">Tissue repair</td><td class="g">Anti-inflammatory</td><td class="g">Antimicrobial</td></tr>
<tr><td><strong>Best for</strong></td><td>Leaky gut, ulcers, mucosal damage</td><td>IBD, IBS, chronic inflammation</td><td>SIBO, infections, dysbiosis</td></tr>
<tr><td><strong>Onset of effects</strong></td><td>1&ndash;2 weeks</td><td>3&ndash;7 days</td><td>1&ndash;2 weeks</td></tr>
<tr><td><strong>Preferred route</strong></td><td>Oral</td><td>Oral</td><td>Oral</td></tr>
<tr><td><strong>Safety profile</strong></td><td class="g">Excellent</td><td class="g">Excellent</td><td class="y">Good (watch for die-off)</td></tr>
<tr><td><strong>Research depth</strong></td><td class="g">Extensive (animal)</td><td class="y">Moderate (preclinical)</td><td class="g">Extensive</td></tr>
