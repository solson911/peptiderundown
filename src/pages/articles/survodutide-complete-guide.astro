<thead><tr><th>Trial Phase</th><th>Key Findings</th><th>Status</th></tr></thead>
<tbody>
<tr><td><strong>Phase 1</strong></td><td>Safe at therapeutic doses, once-weekly dosing confirmed</td><td class="g">Complete</td></tr>
<tr><td><strong>Phase 2</strong></td><td>18.7% avg weight loss, improved HbA1c and lipids</td><td class="g">Complete</td></tr>
<tr><td><strong>Phase 3</strong></td><td>Larger populations, long-term safety data collection</td><td class="y">Ongoing</td></tr>
</tbody>
</table>

<!-- ========== COMPARISON ========== -->
