<tr><td><strong><a href="/articles/tirzepatide-complete-guide">Tirzepatide</a></strong></td><td>GLP-1 + GIP</td><td class="y">15&ndash;22%</td><td>FDA Approved</td></tr>
<tr><td><strong><a href="/articles/semaglutide-weight-loss-guide">Semaglutide</a></strong></td><td>GLP-1 only</td><td class="y">12&ndash;17%</td><td>FDA Approved</td></tr>
</tbody>
