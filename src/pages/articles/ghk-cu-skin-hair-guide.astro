    <tr><td>Normal / Combination</td><td>0.5%</td><td>1.0%</td><td class="g">2-4 weeks</td></tr>
    <tr><td>Resilient / Oily</td><td>0.5-1.0%</td><td>1.5%</td><td class="g">1-2 weeks</td></tr>
    <tr><td>Mature / Sun-damaged</td><td>0.5%</td><td>1.5%</td><td class="y">3-4 weeks</td></tr>
