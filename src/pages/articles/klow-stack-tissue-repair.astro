<tr><td><strong>Weeks 3-4</strong></td><td>BPC/TB/KPV: 500 mcg each, GHK-Cu: 2.5 mg</td><td>15 units (0.15 mL)</td></tr>
<tr><td><strong>Weeks 5-8</strong></td><td>BPC/TB/KPV: 750 mcg each, GHK-Cu: 3.75 mg</td><td>22.5 units (0.225 mL)</td></tr>
<tr><td><strong>Weeks 9-12 (maintain)</strong></td><td>BPC/TB/KPV: 500 mcg each, GHK-Cu: 2.5 mg</td><td>15 units (0.15 mL)</td></tr>
