  title: "The KLOW Stack: BPC-157, TB-500 and GHK-Cu for Complete Tissue Repair",
  description: "The KLOW peptide stack combines BPC-157, TB-500, and GHK-Cu to address distinct healing pathways. Mechanisms, dosing protocols, synergy, timelines, and safety explained without the hype.",
  image: "/images/articles/klow-stack.webp",
  date: "2026-02-17",
  category: "Peptide Stacks",
  author: "PeptideRundown Team"
};
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const rawCSS = `
