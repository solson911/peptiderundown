const rawHTML = `
<div class="c">

<!-- Hero -->
<div class="hero">
  <div class="hero-k">Peptide Stack &middot; Tissue Repair &middot; Recovery</div>
  <h1>The KLOW Stack: BPC-157, TB-500, GHK-Cu and KPV for Complete Tissue Repair</h1>
  <p class="sub">Four peptides targeting distinct healing pathways - angiogenesis, structural remodeling, collagen synthesis, and inflammation control. How the KLOW stack works, what the research says, and practical dosing protocols.</p>
  <div class="pills">
    <span class="pill">BPC-157 &middot; Gastric Pentadecapeptide</span>
    <span class="pill">TB-500 &middot; Thymosin Beta-4</span>
    <span class="pill">GHK-Cu &middot; Copper Tripeptide</span>
