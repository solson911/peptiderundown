    <rect x="220" y="230" width="160" height="40" rx="10" fill="#E4F5EF" stroke="#187A62" stroke-width="1.5"/>
    <text x="300" y="255" text-anchor="middle" font-size="10" font-weight="600" fill="#187A62">Lipolysis + Fat Burning</text>

    <!-- Blocked effects (right side) -->
    <rect x="460" y="30" width="210" height="140" rx="10" fill="#FDEEEC" stroke="#B53A3A" stroke-width="1.5"/>
