---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact"
  description="Contact PeptideRundown for corrections, source notes, editorial questions, and partnership inquiries."
>
  <section class="bg-surface py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="text-sm font-bold uppercase tracking-wide text-primary mb-3">Contact</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-text mb-6">Corrections, tips, and editorial questions.</h1>
      <div class="prose prose-lg prose-slate max-w-none">
        <p>For corrections, source suggestions, news tips, or business inquiries, email us at <a href="mailto:hello@peptiderundown.com">hello@peptiderundown.com</a>.</p>
        <p>Please include the page URL and a short note explaining the issue or request. For correction requests, links to primary sources are especially helpful.</p>
        <h2>Important Note</h2>
        <p>We cannot provide personal medical advice, dosing instructions, diagnosis, treatment recommendations, or help sourcing peptides.</p>
      </div>
    </div>
  </section>
</Base>
